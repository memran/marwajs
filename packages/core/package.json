{
  "name": "marwajs",
  "version": "0.1.0",
  "type": "module",
  "description": "MarwaJS — tiny, fast, composition-API framework without VDOM. SFCs via Vite.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite-plugin-marwa.d.ts",
      "import": "./dist/vite-plugin-marwa.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:play": "vite --config playground/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "vite": "^5.4.0"
  }
}
